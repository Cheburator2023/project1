KEYCLOAK_USER=test_ds
KEYCLOAK_PWD=test_ds

NODE_TLS_REJECT_UNAUTHORIZED=0
NODE_ENV=development
BI_DATAMART_ENABLED=false

TZ=Europe/Moscow
SESSION_SECRET=my-secret

# Kubernetes Settings
KUBERNETES_NAMESPACE=dk1-sumd01-sumd-core
POD_IP=10.244.1.25
NODE_NAME=dk1-sumd01-node-05
POD_NAME=surm-backend-7c8b5d9f6-abc123

# TSLG Agent Configuration
TSLG_AGENT_HOST=tslg-agent-svc-main.dk1-sumd01-sumd-core.svc.cluster.local
TSLG_AGENT_PORT=5170
TSLG_RECONNECTION_DELAY_MS=2000
TSLG_CONNECTION_TTL_MS=2000
TSLG_CLIENT_VERSION=1.0.0

# TSLG Advanced Settings
TSLG_ENABLE_TRACE_FIELDS=true
TSLG_MAX_BUFFER_SIZE=500
TSLG_SOCKET_TIMEOUT_MS=5000
TSLG_CONSOLE_OUTPUT=true
TSLG_ENABLE_FULL_CONTEXT=true
TSLG_BUFFER_FLUSH_INTERVAL_MS=100
TSLG_MAX_CONNECTION_ATTEMPTS=10

# TSLG Data Sanitization
TSLG_SANITIZE_PERCENTAGE=60
TSLG_ENABLE_USER_DATA=true
TSLG_SANITIZE_SENSITIVE_DATA=true

# TSLG Log Level Configuration
TSLG_LOG_LEVEL=info

# TSLG User Fields Mapping
TSLG_USER_ID=sub
TSLG_USER_USERNAME=preferred_username
TSLG_USER_EMAIL=email
TSLG_USER_FIRSTNAME=given_name
TSLG_USER_LASTNAME=family_name

# Application Logging Configuration
APP_NAME=surm-backend
PROJECT_CODE=SURM
RIS_CODE=1404

# Application Settings
NODE_ENV=production

# Debug Settings (в production false)
DEBUG_JSON=true